PORT=4000
DATABASE_URL="file:./dev.db"

# GitHub OAuth (app GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Webhook : secret configuré sur le dépôt GitHub
GITHUB_WEBHOOK_SECRET=

# JWT pour les sessions après OAuth (à remplacer en prod)
JWT_SECRET=change-me-in-production

# Dev : ne pas appeler l’API GitHub, utiliser un utilisateur fictif
DEV_SKIP_AUTH=false
DEV_GITHUB_USERNAME=dev-local

# Origines CORS (frontend Next.js par défaut)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
