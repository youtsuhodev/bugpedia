{
  "name": "bugpedia",
  "displayName": "Bugpedia",
  "description": "Rechercher des bugs et solutions Bugpedia depuis VS Code",
  "version": "0.1.0",
  "publisher": "bugpedia",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:bugpedia.searchError"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Bugpedia",
      "properties": {
        "bugpedia.apiUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "URL de base de l’API Bugpedia (NestJS)"
        }
      }
    },
    "commands": [
      {
        "command": "bugpedia.searchError",
        "title": "Bugpedia: Search for this error"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
